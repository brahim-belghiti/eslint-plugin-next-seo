{
  "name": "eslint-plugin-next-seo",
  "version": "0.7.0",
  "description": "ESLint plugin to catch SEO mistakes in Next.js App Router metadata at build time",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "eslintplugin",
    "next",
    "nextjs",
    "next.js",
    "seo",
    "metadata",
    "app-router"
  ],
  "license": "MIT",
  "author": "Brahim Belghiti <brahim.belghiti@proton.me>",
  "homepage": "https://github.com/brahim-belghiti/eslint-plugin-next-seo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brahim-belghiti/eslint-plugin-next-seo.git"
  },
  "bugs": {
    "url": "https://github.com/brahim-belghiti/eslint-plugin-next-seo/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "next-seo": "dist/cli.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.18.0",
    "@typescript-eslint/utils": "^8.18.0"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/rule-tester": "^8.18.0",
    "eslint": "^9.16.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
